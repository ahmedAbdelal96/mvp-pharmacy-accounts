# ============================================================
# Pharmacy Accounts Lite — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/pharmacy_accounts"

# ─── Auth ─────────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret and keep it private.
# Generate with: openssl rand -base64 32
# In production (NODE_ENV=production): this is REQUIRED and will throw if missing.
# In development: falls back to "dev-secret-change-in-production" (do not use in prod).
AUTH_SECRET=""

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"